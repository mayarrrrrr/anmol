rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read the love note. Only the signed-in client email can write it.
    match /site/message {
      allow read: if true;
      allow write: if request.auth != null
                    && request.auth.token.email == 'akokmayar607@gmail.com';
    }
  }
}
